{
  "name": "ha-haier-evo-tracker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run fix && tsc -b && vite build",
    "build:no-lint": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "fix": "npm run format:fix && npm run lint:fix"
  },
  "dependencies": {
    "@mantine/core": "^7",
    "@mantine/hooks": "^7",
    "@mantine/notifications": "^7",
    "react": "^19",
    "react-dom": "^19",
    "zustand": "^5"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@ianvs/prettier-plugin-sort-imports": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "eslint-plugin-react-hooks": "^5",
    "eslint-plugin-react-refresh": "^0.4",
    "globals": "^16",
    "postcss": "^8",
    "postcss-preset-mantine": "^1",
    "postcss-simple-vars": "^7",
    "prettier": "^3",
    "typescript": "~5.9",
    "typescript-eslint": "^8",
    "vite": "^7"
  }
}
