{
  "bracketSpacing": true,
  "printWidth": 80,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "useTabs": false,
  "trailingComma": "all",
  "arrowParens": "always",
  "bracketSameLine": false,
  "endOfLine": "lf",
  "singleAttributePerLine": true,
  "plugins": ["@ianvs/prettier-plugin-sort-imports"],
  "importOrder": [
    "^(react|react-dom)(/.*)?$",
    "<THIRD_PARTY_MODULES>",
    "^@app(/.*)?$",
    "^@pages(/.*)?$",
    "^@widgets(/.*)?$",
    "^@features(/.*)?$",
    "^@entities(/.*)?$",
    "^@shared(/.*)?$",
    "^[.][.]",
    "^[.]"
  ],
  "importOrderParserPlugins": ["typescript", "jsx"],
  "importOrderTypeScriptVersion": "5.0.0",
  "importOrderCaseSensitive": false
}
